    {
      "cell_type": "code",
      "source": [
        "# Risk level summary\n",
        "risk_order = [\"Low\", \"Medium\", \"High\"]\n",
        "\n",
        "risk_churn = df_dash.groupby(\"risk_level\").agg(\n",
        "    customers=(\"customer_id\", \"count\"),\n",
        "    churn_rate=(\"churned_next_30d\", \"mean\")\n",
        ").reset_index()\n",
        "\n",
        "risk_churn[\"churn_rate\"] *= 100\n",
        "risk_churn[\"risk_level\"] = pd.Categorical(\n",
        "    risk_churn[\"risk_level\"],\n",
        "    categories=risk_order,\n",
        "    ordered=True\n",
        ")\n",
        "risk_churn = risk_churn.sort_values(\"risk_level\")\n",
        "\n",
        "\n",
        "# Package renewal summary\n",
        "renewal_churn = df_dash.groupby(\"package_renewed\").agg(\n",
        "    customers=(\"customer_id\", \"count\"),\n",
        "    churn_rate=(\"churned_next_30d\", \"mean\")\n",
        ").reset_index()\n",
        "\n",
        "renewal_churn[\"churn_rate\"] *= 100\n",
        "\n",
        "\n",
        "# Warning flag churn summary\n",
        "flag_cols = {\n",
        "    \"Low Activity\": \"low_activity_flag\",\n",
        "    \"Non-Renewed Package\": \"non_renewed_flag\",\n",
        "    \"High Complaints\": \"high_complaint_flag\",\n",
        "    \"High Network Issues\": \"high_network_issue_flag\"\n",
        "}\n",
        "\n",
        "driver_data = []\n",
        "\n",
        "for label, col in flag_cols.items():\n",
        "    affected = df_dash[df_dash[col] == 1]\n",
        "\n",
        "    if len(affected) > 0:\n",
        "        driver_data.append({\n",
        "            \"driver\": label,\n",
        "            \"customers\": len(affected),\n",
        "            \"churn_rate\": affected[\"churned_next_30d\"].mean() * 100\n",
        "        })\n",
        "\n",
        "driver_churn = pd.DataFrame(driver_data).sort_values(\n",
        "    \"churn_rate\",\n",
        "    ascending=False\n",
        ")\n",
        "\n",
        "\n",
        "# Revenue at risk by region\n",
        "region_revenue = df_dash.groupby(\"region\").agg(\n",
        "    revenue_at_risk=(\"revenue_at_risk\", \"sum\"),\n",
        "    customers=(\"customer_id\", \"count\"),\n",
        "    churned=(\"churned_next_30d\", \"sum\")\n",
        ").reset_index()\n",
        "\n",
        "region_revenue = region_revenue.sort_values(\n",
        "    \"revenue_at_risk\",\n",
        "    ascending=False\n",
        ").head(8)"
      ],
