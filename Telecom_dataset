    {
      "cell_type": "markdown",
      "source": [
        "Creating Chrun Risk score"
      ],
      "metadata": {
        "id": "OPcXvtipnmrb"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "df_clean[\"risk_score\"] = 0\n",
        "\n",
        "df_clean.loc[df_clean[\"usage_drop_pct\"] > 0.50, \"risk_score\"] += 30\n",
        "df_clean.loc[df_clean[\"package_renewed\"] == \"No\", \"risk_score\"] += 25\n",
        "df_clean.loc[df_clean[\"active_days_30d\"] <= 5, \"risk_score\"] += 20\n",
        "df_clean.loc[df_clean[\"complaint_count_30d\"] == 2, \"risk_score\"] += 15\n",
        "df_clean.loc[df_clean[\"complaint_count_30d\"] >= 3, \"risk_score\"] += 20\n",
        "df_clean.loc[df_clean[\"network_issue_count_30d\"].between(3, 4), \"risk_score\"] += 10\n",
        "df_clean.loc[df_clean[\"network_issue_count_30d\"] >= 5, \"risk_score\"] += 20\n",
        "df_clean.loc[df_clean[\"days_since_last_usage\"] >= 14, \"risk_score\"] += 10\n",
        "\n",
        "df_clean[\"risk_score\"] = df_clean[\"risk_score\"].clip(upper=100)"
      ],
      "metadata": {
        "id": "fg1uPkp0nliy"
      },
      "execution_count": 35,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "The score is based on this logic:\n",
        "\n",
        "Factor\tWhy it matters\tPoints\n",
        "Usage dropped > 50%\tCustomer engagement is falling,\t+30 points\n",
        "Package not renewed\tCustomer may stop paying/using\t+25 points\n",
        "Active days <= 5\tCustomer is almost inactive\t+20points\n",
        "2 complaints\tDissatisfaction warning\t+15points\n",
        "3+ complaints\tStrong dissatisfaction\t+20 points\n",
        "3–4 network issues\tModerate service problem\t+10 points\n",
        "5+ network issues\tSerious service problem\t+20 points\n",
        "No usage for 14+ days\tInactivity warning\t+10 points\n",
        "Risk score is between 0 and 100 for easier interpretation."
      ],
      "metadata": {
        "id": "r-68rwBrrXwT"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def assign_risk_level(score):\n",
        "    if score <= 30:\n",
        "        return \"Low\"\n",
        "    elif score <= 60:\n",
        "        return \"Medium\"\n",
        "    else:\n",
        "        return \"High\"\n",
        "\n",
        "df_clean[\"risk_level\"] = df_clean[\"risk_score\"].apply(assign_risk_level)"
      ],
      "metadata": {
        "id": "tAqn0_nmntbZ"
      },
      "execution_count": 36,
      "outputs": []
    },
