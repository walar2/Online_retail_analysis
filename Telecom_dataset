        "def churn_summary(group_col):\n",
        "    summary = df_dash.groupby(group_col).agg(\n",
        "        customers=(\"customer_id\", \"count\"),\n",
        "        churned=(\"churned_next_30d\", \"sum\"),\n",
        "        churn_rate=(\"churned_next_30d\", \"mean\"),\n",
        "        avg_arpu=(\"arpu_usd\", \"mean\"),\n",
        "        avg_risk_score=(\"risk_score\", \"mean\"),\n",
        "        revenue_at_risk=(\"revenue_at_risk\", \"sum\")\n",
        "    ).reset_index()\n",
        "\n",
        "    summary[\"churn_rate\"] = summary[\"churn_rate\"] * 100\n",
        "    summary[\"avg_arpu\"] = summary[\"avg_arpu\"].round(2)\n",
        "    summary[\"avg_risk_score\"] = summary[\"avg_risk_score\"].round(1)\n",
        "    summary[\"revenue_at_risk\"] = summary[\"revenue_at_risk\"].round(2)\n",
        "\n",
        "    return summary.sort_values(\"churn_rate\", ascending=False)"
      ],
      "metadata": {
        "id": "YYcitXinwI6C"
      },
